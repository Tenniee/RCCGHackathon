"""
Alembic migration environment.
Reads DATABASE_URL from .env via pydantic-settings.
Neon PostgreSQL requires sslmode=require — this is handled automatically
when the URL contains 'neon.tech'.
"""
 
import os
from logging.config import fileConfig
 
from sqlalchemy import engine_from_config, pool
from alembic import context
 
# Load .env before importing app modules
from dotenv import load_dotenv
load_dotenv()
 
# This imports all models so Alembic can detect schema changes
from app.core.database import Base
import app.models  # noqa: F401 — registers all ORM classes
 
from app.core.config import get_settings
 
settings = get_settings()
 
# Alembic Config object (gives access to alembic.ini values)
config = context.config
 
# Override sqlalchemy.url with our env-based URL
db_url = settings.DATABASE_URL
 
# Neon requires sslmode=require; append if missing
if "neon.tech" in db_url and "sslmode" not in db_url:
    connector = "&" if "?" in db_url else "?"
    db_url = f"{db_url}{connector}sslmode=require"
 
config.set_main_option("sqlalchemy.url", db_url)
 
# Logging setup from alembic.ini
if config.config_file_name is not None:
    fileConfig(config.config_file_name)
 
target_metadata = Base.metadata
 
 
def run_migrations_offline() -> None:
    """Run migrations without a live DB connection (generates SQL script)."""
    url = config.get_main_option("sqlalchemy.url")
    context.configure(
        url=url,
        target_metadata=target_metadata,
        literal_binds=True,
        dialect_opts={"paramstyle": "named"},
        compare_type=True,
    )
    with context.begin_transaction():
        context.run_migrations()
 
 
def run_migrations_online() -> None:
    """Run migrations against the live Neon database."""
    connectable = engine_from_config(
        config.get_section(config.config_ini_section, {}),
        prefix="sqlalchemy.",
        poolclass=pool.NullPool,  # NullPool is best for serverless / Neon
    )
    with connectable.connect() as connection:
        context.configure(
            connection=connection,
            target_metadata=target_metadata,
            compare_type=True,   # detect column type changes
        )
        with context.begin_transaction():
            context.run_migrations()
 
 
if context.is_offline_mode():
    run_migrations_offline()
else:
    run_migrations_online()
 