# ─── Database ─────────────────────────────────────────────────────────────────
# Paste your Neon connection string here — get it from neon.tech dashboard
# It looks like: postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/rccg_ride_connect
DATABASE_URL='postgresql://neondb_owner:npg_pCUvIczyK2L9@ep-cool-frost-af45s6ic-pooler.c-2.us-west-2.aws.neon.tech/rccg_transport?sslmode=require&channel_binding=require'

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret by running this in your terminal:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get these from cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000